# Copy to .env and fill in. Only OPENROUTER_API_KEY is required.

OPENROUTER_API_KEY=sk-or-v1-...

# ---------------------------------------------------------------------------
# Optional model overrides (OpenRouter IDs).
# Defaults live in backend/config.py and were verified against OpenRouter.
# Override here ONLY if a default 404s or you want a different model. Verify
# IDs at https://openrouter.ai/models if a call fails.
# ---------------------------------------------------------------------------

# Google Gemini
# MODEL_GEMINI_FLASH=google/gemini-2.5-flash
# MODEL_GEMINI_PRO=google/gemini-2.5-pro

# Anthropic
# MODEL_CLAUDE_HAIKU=anthropic/claude-haiku-4.5
# MODEL_CLAUDE_SONNET=anthropic/claude-sonnet-4.5
# MODEL_CLAUDE_OPUS=anthropic/claude-opus-4.6

# OpenAI
# MODEL_GPT=openai/gpt-5.1

# xAI Grok (x-ai/grok-4 is deprecated; default is grok-4.3)
# MODEL_GROK=x-ai/grok-4.3

# Title generation (cheap/fast). Defaults to the cheap Gemini model.
# MODEL_TITLE=google/gemini-2.5-flash
